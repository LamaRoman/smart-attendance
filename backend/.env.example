DATABASE_URL="postgresql://user:password@localhost:5432/smart_attendance"
JWT_SECRET="generate-with-crypto-randomBytes-64"
JWT_EXPIRES_IN="7d"
TOTP_ISSUER="SmartAttendance"
NODE_ENV="development"
PORT="5001"
CORS_ORIGINS="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
CALENDARIFIC_API_KEY="your-calendarific-key"
RESEND_API_KEY="re_your_resend_key"
FROM_EMAIL="onboarding@resend.dev"
SUPER_ADMIN_EMAIL="admin@smartattendance.com"
SUPER_ADMIN_PASSWORD="change-this-to-a-strong-password"

# Seed credentials — required by `npm run db:seed`. No fallbacks
# in source: hardcoded passwords were removed in commit 4b0edb1
# (2026-04-05). Choose your own values; these are dev-only fixtures.
SEED_ORG_ADMIN_PASSWORD="change-me-org-admin"
SEED_EMPLOYEE_PASSWORD="change-me-employee"
SEED_EMPLOYEE_PIN="0000"

AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="smart-hr-documents"