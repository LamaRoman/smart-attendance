// ============================================================
// SMART ATTENDANCE SYSTEM - Prisma Schema
// Multi-tenant, Nepal-specific, QR attendance ready
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN // Platform-level admin  manages all orgs
  ORG_ADMIN // Organization admin  manages their org
  EMPLOYEE // Regular employee
}

enum AttendanceAction {
  CLOCK_IN
  CLOCK_OUT
}

enum AttendanceRecordStatus {
  CHECKED_IN // Employee has clocked in, not yet clocked out
  CHECKED_OUT // Normal completed shift
  AUTO_CLOSED // System auto-closed (e.g., forgot to clock out)
}

enum AttendanceMode {
  QR_ONLY
  MOBILE_ONLY
  BOTH
}
enum CheckInMethod {
  QR_SCAN
  MOBILE_CHECKIN
  MANUAL // Admin manually clocked in/out
}

enum QRCodeStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  APPROVED
  PAID
  NEEDS_RECALCULATION
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  MATERNITY
  PATERNITY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HolidayType {
  PUBLIC_HOLIDAY
  RESTRICTED_HOLIDAY
  ORGANIZATION_HOLIDAY
}

enum Language {
  NEPALI
  ENGLISH
}

enum CalendarMode {
  NEPALI // BS dates, Nepali month names, Nepali digits
  ENGLISH // AD dates, English month names
}

// ============================================================
// ORGANIZATION  Multi-tenant root
// ============================================================
model Organization {
  id                 String  @id @default(uuid())
  name               String
  slug               String?  @unique
  email              String?
  phone              String?
  address            String?
  isActive           Boolean @default(true)
  staticQREnabled    Boolean @default(true)
  rotatingQREnabled  Boolean @default(true)

  // Calendar/locale preference (toggleable by org)
  calendarMode    CalendarMode @default(NEPALI)
  language        Language     @default(NEPALI)
  // Geofencing
  geofenceEnabled Boolean      @default(false)
  officeLat       Float?
  officeLng       Float?
  geofenceRadius  Int          @default(100) // meters
  attendanceMode   AttendanceMode @default(QR_ONLY)

  // Work schedule
  workStartTime        String @default("10:00") // HH:mm format
  workEndTime          String @default("18:00")
  lateThresholdMinutes Int    @default(10)
  workingDays          String @default("0,1,2,3,4,5") // 0=Sun,1=Mon,...6=Sat

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  // Relations
  users             User[]
  attendanceRecords AttendanceRecord[]
  qrCodes           QRCode[]
  holidays          Holiday[]
  leaves            Leave[]
  paySettings       EmployeePaySettings[]
  payrollRecords    PayrollRecord[]
  payrollAuditLogs  PayrollAuditLog[]
  systemConfigs     SystemConfig[]

  notifications Notification[]
  documents     EmployeeDocument[]

  documentTypes DocumentType[]
  subscription   OrgSubscription?
  @@map("organizations")
}

// ============================================================
// USER
// ============================================================
model User {
  id         String  @id @default(uuid())
  email      String  @unique
  password   String
  attendancePinHash  String?
  firstName  String
  lastName   String
  employeeId String? @unique
  phone      String?
  role       Role    @default(EMPLOYEE)
  isActive   Boolean @default(true)

  platformId String? @unique

  // Individual shift override (null = follow org default)
  shiftStartTime String? // HH:mm format, e.g. "14:00"
  shiftEndTime   String? // HH:mm format, e.g. "18:00"

  // Multi-tenant  NULL only for SUPER_ADMIN
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  // Relations
  sessions          UserSession[]
  attendanceRecords AttendanceRecord[]
  paySettings       EmployeePaySettings?
  payrollRecords    PayrollRecord[]
  requestedLeaves   Leave[]              @relation("RequestedLeaves")
  approvedLeaves    Leave[]              @relation("ApprovedLeaves")
  createdQRCodes    QRCode[]             @relation("QRCodeCreator")

  notifications Notification[]
  documents     EmployeeDocument[]

  @@index([organizationId])
  passwordResetTokens PasswordResetToken[]
  @@map("users")
}

// ============================================================
// USER SESSION  JWT token tracking for secure logout
// ============================================================
model UserSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique // SHA-256 hash of the JWT
  isValid   Boolean  @default(true) // Allows invalidation without deletion
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([userId, isValid])
  @@map("user_sessions")
}

// ============================================================
// ============================================================
// QR CODE  Generated for attendance scanning
// ============================================================
model QRCode {
  id        String @id @default(uuid())
  token     String @unique
  signature String

  status    QRCodeStatus @default(ACTIVE)
  scanCount Int          @default(0)
  expiresAt DateTime? // Optional auto-expiry

  // Who/what generated it
  createdById String
  createdBy   User   @relation("QRCodeCreator", fields: [createdById], references: [id])


  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  attendanceRecords AttendanceRecord[]

  @@index([organizationId])
  @@index([token])
  @@map("qr_codes")
}

// ============================================================
// ATTENDANCE RECORD  Clock-in / Clock-out tracking
// One record per shift (not per day  supports multiple shifts)
// ============================================================
model AttendanceRecord {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  checkInTime    DateTime       @default(now())
  checkOutTime   DateTime?
  checkInMethod  CheckInMethod  @default(QR_SCAN)
  checkOutMethod CheckInMethod?

  duration Int? // Duration in minutes
  status   AttendanceRecordStatus @default(CHECKED_IN)

  // Which QR code was scanned (nullable for MANUAL entries)
  qrCodeId String?
  qrCode   QRCode? @relation(fields: [qrCodeId], references: [id])

  notes    String?
  isActive Boolean @default(true) // Soft delete

  // Manual correction tracking
  isManualEntry    Boolean   @default(false)
  modifiedBy       String? // Admin userId who made the change
  modifiedAt       DateTime?
  modificationNote String? // Mandatory reason for manual changes
  originalCheckIn  DateTime? // Preserved original time before edit
  originalCheckOut DateTime?

  // Nepali date fields (denormalized for fast queries/reports)
  bsYear  Int?
  bsMonth Int?
  bsDay   Int?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]

  @@index([userId])
  @@index([organizationId])
  @@index([checkInTime])
  @@index([userId, checkInTime])
  @@index([bsYear, bsMonth])
  @@index([organizationId, bsYear, bsMonth])
  @@index([userId, bsYear, bsMonth])
  @@map("attendance_records")
}

// ============================================================
// ATTENDANCE AUDIT LOG  Every scan attempt (success + failure)
// ============================================================
model AttendanceAuditLog {
  id             String  @id @default(uuid())
  employeeId     String? // The employee ID entered (may not match a real user)
  userId         String? // Resolved user ID (null if employee not found)
  organizationId String?

  action    String // CLOCK_IN, CLOCK_OUT, FAILED
  method    String // QR_SCAN, MANUAL
  ipAddress String?
  userAgent String?

  success       Boolean
  failureReason String? // e.g., "COOLDOWN_ACTIVE", "INVALID_QR", "EMPLOYEE_NOT_FOUND"

  qrToken      String? // The token that was scanned (for debugging)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
  @@index([ipAddress])
  @@map("attendance_audit_log")
}

// ============================================================
// EMPLOYEE PAY SETTINGS  Per-employee salary configuration
// ============================================================
model EmployeePaySettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  basicSalary         Decimal @db.Decimal(12, 2)
  dearnessAllowance   Decimal @default(0) @db.Decimal(12, 2)
  transportAllowance  Decimal @default(0) @db.Decimal(12, 2)
  medicalAllowance    Decimal @default(0) @db.Decimal(12, 2)
  otherAllowances     Decimal @default(0) @db.Decimal(12, 2)
  overtimeRatePerHour Decimal @default(0) @db.Decimal(10, 2)

  // SSF (Social Security Fund)  Nepal specific
  ssfEnabled       Boolean @default(true)
  employeeSsfRate  Decimal @default(11) @db.Decimal(5, 2) // 11
  employerSsfRate  Decimal @default(20) @db.Decimal(5, 2) // 20
  // PF (Provident Fund)  10 each
  pfEnabled        Boolean @default(false)
  employeePfRate   Decimal @default(10) @db.Decimal(5, 2)
  employerPfRate   Decimal @default(10) @db.Decimal(5, 2)
  // CIT (Citizen Investment Trust)  optional, tax-deductible
  citEnabled       Boolean @default(false)
  citAmount        Decimal @default(0) @db.Decimal(12, 2)
  // Marital status  affects TDS first slab
  isMarried        Boolean @default(false)
  // Advance/Loan deductions
  advanceDeduction Decimal @default(0) @db.Decimal(12, 2)

  // TDS (Tax Deducted at Source)
  tdsEnabled Boolean @default(true)

  // Bank details
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  @@index([organizationId])
  @@index([userId])
  @@map("employee_pay_settings")
}

// ============================================================
// PAYROLL RECORD  Monthly payroll calculation results
// ============================================================
model PayrollRecord {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Period  both AD and BS
  year    Int // AD year
  month   Int // AD month
  bsYear  Int // BS year
  bsMonth Int // BS month

  // Attendance summary for this period
  workingDaysInMonth Int
  holidaysInMonth    Int     @default(0)
  daysPresent        Int
  daysAbsent         Int
  paidLeaveDays      Int     @default(0)
  unpaidLeaveDays    Int     @default(0)
  overtimeHours      Decimal @default(0) @db.Decimal(8, 2)

  // Earnings
  basicSalary        Decimal @db.Decimal(12, 2)
  dearnessAllowance  Decimal @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal @default(0) @db.Decimal(12, 2)
  medicalAllowance   Decimal @default(0) @db.Decimal(12, 2)
  otherAllowances    Decimal @default(0) @db.Decimal(12, 2)
  overtimePay        Decimal @default(0) @db.Decimal(12, 2)
  grossSalary        Decimal @db.Decimal(12, 2)

  // Deductions
  absenceDeduction Decimal @default(0) @db.Decimal(12, 2)
  employeeSsf      Decimal @default(0) @db.Decimal(12, 2)
  employerSsf      Decimal @default(0) @db.Decimal(12, 2)
  employeePf       Decimal @default(0) @db.Decimal(12, 2)
  employerPf       Decimal @default(0) @db.Decimal(12, 2)
  citDeduction     Decimal @default(0) @db.Decimal(12, 2)
  advanceDeduction Decimal @default(0) @db.Decimal(12, 2)
  dashainBonus     Decimal @default(0) @db.Decimal(12, 2)
  isMarried        Boolean @default(false)
  tds              Decimal @default(0) @db.Decimal(12, 2)
  otherDeductions  Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions  Decimal @default(0) @db.Decimal(12, 2)

  // Final
  netSalary Decimal @db.Decimal(12, 2)

  // Workflow
  status      PayrollStatus @default(DRAFT)
  processedAt DateTime?
  approvedAt  DateTime?
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  // One payroll record per employee per BS month
  @@unique([userId, bsYear, bsMonth])
  @@index([organizationId])
  @@index([bsYear, bsMonth])
  @@index([userId, bsYear, bsMonth])
  @@index([organizationId, bsYear, bsMonth])
  @@index([status])
  @@map("payroll_records")
}

// ============================================================
// HOLIDAY  Supports both national and org-specific holidays
// With full BS date support
// ============================================================
model Holiday {
  id String @id @default(uuid())

  // Multi-tenant  NULL = national holiday for all orgs
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name       String
  nameNepali String? //  

  // AD date
  date DateTime @db.Date

  // BS date (denormalized for fast lookup)
  bsYear  Int
  bsMonth Int
  bsDay   Int

  type        HolidayType @default(PUBLIC_HOLIDAY)
  isRecurring Boolean     @default(false)
  isActive    Boolean     @default(true)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  // Unique per BS date (per org or national)
  @@unique([bsYear, bsMonth, bsDay, organizationId])
  @@index([organizationId])
  @@index([date])
  @@index([bsYear, bsMonth])
  @@index([organizationId, bsYear])
  @@map("holidays")
}

// ============================================================
// LEAVE  Employee leave requests
// ============================================================
model Leave {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("RequestedLeaves", fields: [userId], references: [id], onDelete: Cascade)

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  // BS dates for the leave period
  bsStartYear  Int?
  bsStartMonth Int?
  bsStartDay   Int?
  bsEndYear    Int?
  bsEndMonth   Int?
  bsEndDay     Int?

  reason String
  rejectionMessage String?
  type   LeaveType
  status LeaveStatus @default(PENDING)

  approvedBy String?
  approver   User?     @relation("ApprovedLeaves", fields: [approvedBy], references: [id])
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  @@index([userId])
  @@index([organizationId])
  @@index([userId, status])
  @@index([organizationId, status])
  @@index([startDate, endDate])
  @@map("leaves")
}

// ============================================================
// SYSTEM CONFIG  Key-value settings per organization
// ============================================================
model SystemConfig {
  id String @id @default(uuid())

  // Multi-tenant
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  key         String
  value       String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  // One key per organization
  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("system_configs")
}

model Notification {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String

  userId       String?
  user         User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendanceId String?
  attendance   AttendanceRecord? @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  @@index([organizationId, isRead, createdAt])
  @@index([userId])
}

enum NotificationType {
  LATE_ARRIVAL
  EARLY_DEPARTURE
  LEAVE_REQUEST
  PAYROLL_APPROVED
  SYSTEM_ALERT

  ORG_STATUS_CHANGED
  PAYROLL_TOGGLED
  LEAVE_TOGGLED
  MASTER_HOLIDAYS_UPDATED
}

// 1. Add the DocumentType model (org-admin defined categories)
model DocumentType {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String // e.g. "Citizenship", "Police Clearance", "Medical Report"
  nameNp      String? // Nepali name (optional)
  description String? // What the employer expects
  isRequired  Boolean @default(false) // Mark as mandatory for employees
  isActive    Boolean @default(true) // Soft disable

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  documents EmployeeDocument[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("document_types")
}

// 2. Add the EmployeeDocument model
model EmployeeDocument {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentTypeId String
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id])

  fileName     String // Stored filename (UUID-based)
  originalName String // Original upload filename
  mimeType     String // e.g. application/pdf, image/jpeg
  fileSize     Int // bytes
  description  String? // Optional note

  uploadedBy String // userId of uploader (employee or admin)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // FIX H-10: soft delete timestamp

  @@index([userId])
  @@index([organizationId])
  @@index([documentTypeId])
  @@map("employee_documents")
}
// ============================================================
// PRICING TIER ADDITIONS  Add to your existing schema.prisma
// ============================================================

// ============================================================
// NEW ENUMS
// ============================================================

enum TierName {
  STARTER      // Free, up to 5 employees
  OPERATIONS   // Rs. 250/employee/month, 6100 employees
}

enum SubscriptionStatus {
  TRIALING     // Within trial period
  GRACE_PERIOD // Trial ended, grace window before downgrade/suspend
  ACTIVE       // Paid and active
  PAST_DUE     // Payment overdue
  SUSPENDED    // Manually suspended by super admin
  CANCELLED    // Org cancelled
  EXPIRED      // Trial ended, not converted
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

// ============================================================
// PRICING PLAN  Defines each tier's rules & pricing
// Super admin configures this. One row per tier.
//
// NOTE: Nepal-specific core features (BS calendar, geofencing,
// holiday sync, SSF, TDS) are intentionally NOT toggleable here.
// They are hardcoded ON in application logic for all tiers.
// Keeping them out of the DB prevents accidental deactivation.
// ============================================================
model PricingPlan {
  id          String   @id @default(uuid())
  tier        TierName @unique

  displayName String   // e.g. "Starter", "Operations"
  description String?

  // Pricing
  pricePerEmployee Decimal @default(0) @db.Decimal(10, 2) // 0 for free tier
  defaultSetupFee  Decimal? @db.Decimal(10, 2)          // null = no setup fee
  currency         String  @default("NPR")

  // Limits  null means unlimited
  maxEmployees     Int?    // 5 for Starter, null for Operations
  hardEmployeeCap  Int?    // Hard ceiling  100 for Operations

  // Trial config
  trialDaysMonthly Int  @default(30)  // 30 days for monthly billing
  annualDiscountPercent Int @default(0)   // e.g. 20 = 20 off when paying annually
  gracePeriodDays  Int  @default(7)   // Days after trial before downgrade/suspend

  // Annual billing discount

  //  Feature flags  super admin can toggle per plan 
  featureLeave             Boolean @default(false)
  featureManualCorrection  Boolean @default(false)
  featureFullPayroll       Boolean @default(false)  // PF, CIT, allowances, Dashain
  featurePayrollWorkflow   Boolean @default(false)
  featureReports           Boolean @default(false)
  featureNotifications     Boolean @default(false)
  featureOnboarding        Boolean @default(false)
  featureAuditLog          Boolean @default(false)
  auditLogRetentionDays    Int?    // null = unlimited, 30 for Operations

  //  File access control 
  // Starter: preview only  no downloads
  // Operations: full download access
  featureFileDownload      Boolean @default(false)
  // Granular download control if needed in future
  featureDownloadReports        Boolean @default(false) // Attendance/payroll reports
  featureDownloadPayslips       Boolean @default(false) // Individual payslips
  featureDownloadAuditLog       Boolean @default(false) // Audit log exports
  featureDownloadLeaveRecords   Boolean @default(false) // Leave history exports

  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  subscriptions OrgSubscription[]

  featureTotp  Boolean  @default(false)

  @@map("pricing_plans")
}

// ============================================================
// ADMIN NOTE  Thread of internal notes per subscription
// Replaces single adminNote string  preserves full history
// ============================================================
model SubscriptionAdminNote {
  id             String          @id @default(uuid())
  subscriptionId String
  subscription   OrgSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  note           String
  createdBy      String          // Super admin userId
  createdAt      DateTime        @default(now())

  @@index([subscriptionId])
  @@map("subscription_admin_notes")
}

// ============================================================
// ORG SUBSCRIPTION  One active subscription per organization
// ============================================================
model OrgSubscription {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  planId         String
  plan           PricingPlan  @relation(fields: [planId], references: [id])

  status         SubscriptionStatus @default(TRIALING)
  billingCycle   BillingCycle       @default(MONTHLY)

  // Trial tracking
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  isTrialUsed    Boolean   @default(false) // Prevents trial abuse on re-signup

  // Trial conversion nudge tracking
  trialReminderSentAt      DateTime? // 7-day reminder sent
  trialFinalReminderAt     DateTime? // 1-day reminder sent
  billingReminderSentAt    DateTime? // 7-day billing renewal reminder sent
  conversionNudgeSentAt    DateTime? // Post-expiry nudge sent
  graceEndsAt              DateTime? // When grace period expires
  gracePeriodReminderSentAt DateTime? // Mid-grace reminder sent

  // Billing dates
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  nextBillingDate       DateTime? // Explicit  shown to org admin as "next bill on X"
  cancelledAt           DateTime?
  suspendedAt           DateTime?

  // Employee count cache  avoids counting User rows on every bill
  currentEmployeeCount  Int @default(0) // Updated on every add/remove employee event

  // Custom pricing override  for special deals
  customPricePerEmployee Decimal? @db.Decimal(10, 2) // null = use plan default
  customPriceExpiresAt   DateTime?              // null = no expiry, auto-reverts when reached
  customMaxEmployees     Int?

  // Per-org feature overrides  null = use plan default, true/false = override
  overrideFeatureLeave             Boolean?
  overrideFeatureManualCorrection  Boolean?
  overrideFeatureFullPayroll       Boolean?
  overrideFeaturePayrollWorkflow   Boolean?
  overrideFeatureReports           Boolean?
  overrideFeatureNotifications     Boolean?
  overrideFeatureOnboarding        Boolean?
  overrideFeatureAuditLog          Boolean?
  overrideFeatureFileDownload      Boolean?
  overrideFeatureDownloadReports   Boolean?
  overrideFeatureDownloadPayslips  Boolean?
  overrideFeatureDownloadAuditLog  Boolean?
  overrideFeatureDownloadLeaveRecords Boolean?
  isPriceLockedForever   Boolean  @default(false)


  // Setup fee
  setupFeePaid       Boolean   @default(false)
  setupFeeAmount     Decimal?  @db.Decimal(10, 2)
  setupFeePaidAt     DateTime?
  setupFeeWaived     Boolean   @default(false)
  setupFeeWaivedBy   String?   // Super admin userId
  setupFeeWaivedNote String?

  // Branch tracking
  parentSubscriptionId String?
  parentSubscription   OrgSubscription?  @relation("BranchSubscriptions", fields: [parentSubscriptionId], references: [id])
  branches             OrgSubscription[] @relation("BranchSubscriptions")

  // Super admin control
  assignedBy   String?   // Super admin userId who last changed the tier
  assignedAt   DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  billingHistory SubscriptionBillingLog[]
  adminNotes     SubscriptionAdminNote[]

  @@index([organizationId])
  @@index([status])
  @@index([planId])
  @@index([trialEndsAt])
  @@index([nextBillingDate])
  @@map("org_subscriptions")
}

// ============================================================
// SUBSCRIPTION BILLING LOG  Full audit trail
// ============================================================
model SubscriptionBillingLog {
  id             String          @id @default(uuid())
  subscriptionId String
  subscription   OrgSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  organizationId String
  performedBy    String?         // Super admin userId (null = system-triggered)

  event          String          // TRIAL_STARTED, TRIAL_ENDED, PLAN_CHANGED,
                                 // PAYMENT_RECEIVED, SUSPENDED, REACTIVATED,
                                 // PRICE_OVERRIDDEN, SETUP_FEE_WAIVED,
                                 // DOWNLOAD_ATTEMPTED, etc.

  fromPlan       String?
  toPlan         String?
  fromStatus     String?
  toStatus       String?

  amount         Decimal? @db.Decimal(10, 2)
  employeeCount  Int?     // Snapshot at billing time
  note           String?

  createdAt      DateTime @default(now())

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("subscription_billing_log")
}
//Platform-level configuration (super admin only) 
// Global settings that apply across all orgs.
// Key-value store with type hints for the UI.
model PlatformConfig {
  id          String   @id @default(uuid())
  key         String   @unique  // e.g. "billing.grace_period_days"
  value       String            // stored as string, parsed by consumer
  valueType   String   @default("number") // "number" | "boolean" | "string"
  label       String            // Human-readable label for super admin UI
  description String?           // Explanation shown in UI
  updatedBy   String?           // userId of last super admin who changed it
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("platform_config")
}

// ============================================================
// PASSWORD RESET TOKEN  FIX C-12: secure welcome email flow
// ============================================================
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String?  @unique
  tokenHash String?  @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ============================================================
// PAYROLL AUDIT LOG  tracks every generate, regenerate, status change,
// and payroll flag triggered by attendance corrections
// ============================================================
model PayrollAuditLog {
  id                 String   @id @default(uuid())
  organizationId     String
  payrollRecordId    String?
  employeeUserId     String?
  action             String   // GENERATED | REGENERATED | STATUS_CHANGED | FLAGGED_NEEDS_RECALCULATION | VOIDED
  fromStatus         String?
  toStatus           String?
  triggeredBy        String   // userId of the admin who triggered this
  reason             String?
  attendanceRecordId String?  // populated when triggered by an attendance correction
  bsYear             Int?
  bsMonth            Int?
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([payrollRecordId])
  @@index([employeeUserId])
  @@map("payroll_audit_logs")
}

