// ============================================================
// SMART ATTENDANCE SYSTEM - Prisma Schema
// Multi-tenant, Nepal-specific, QR attendance ready
// With OrgMembership model for multi-org support
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN    // Platform-level admin — manages all orgs
  ORG_ADMIN      // Organization admin — manages their org
  ORG_ACCOUNTANT // Organization accountant — payroll/reports access
  EMPLOYEE       // Regular employee
}

enum AttendanceAction {
  CLOCK_IN
  CLOCK_OUT
}

enum AttendanceRecordStatus {
  CHECKED_IN   // Employee has clocked in, not yet clocked out
  CHECKED_OUT  // Normal completed shift
  AUTO_CLOSED  // System auto-closed (e.g., forgot to clock out)
}

enum AttendanceMode {
  QR_ONLY
  MOBILE_ONLY
  BOTH
}

enum CheckInMethod {
  QR_SCAN
  MOBILE_CHECKIN
  MANUAL // Admin manually clocked in/out
}

enum QRCodeStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  APPROVED
  PAID
  NEEDS_RECALCULATION
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  MATERNITY
  PATERNITY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HolidayType {
  PUBLIC_HOLIDAY
  RESTRICTED_HOLIDAY
  ORGANIZATION_HOLIDAY
  WORKING_DAY_OVERRIDE
}

enum Language {
  NEPALI
  ENGLISH
}

enum CalendarMode {
  NEPALI  // BS dates, Nepali month names, Nepali digits
  ENGLISH // AD dates, English month names
}

// ============================================================
// ORGANIZATION — Multi-tenant root
// ============================================================
model Organization {
  id                 String  @id @default(uuid())
  name               String
  slug               String? @unique
  email              String?
  phone              String?
  address            String?
  isActive           Boolean @default(true)
  staticQREnabled    Boolean @default(true)
  rotatingQREnabled  Boolean @default(true)

  // Calendar/locale preference (toggleable by org)
  calendarMode   CalendarMode @default(NEPALI)
  language       Language     @default(NEPALI)

  // Geofencing
  geofenceEnabled Boolean @default(false)
  officeLat       Float?
  officeLng       Float?
  geofenceRadius  Int     @default(100) // meters
  attendanceMode  AttendanceMode @default(QR_ONLY)

  // Work schedule
  workStartTime        String @default("10:00") // HH:mm format
  workEndTime          String @default("18:00")
  lateThresholdMinutes Int    @default(10)
  workingDays          String @default("0,1,2,3,4,5") // 0=Sun,1=Mon,...6=Sat

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete timestamp

  // Relations
  memberships       OrgMembership[]
  attendanceRecords AttendanceRecord[]
  qrCodes           QRCode[]
  holidays          Holiday[]
  leaves            Leave[]
  paySettings       EmployeePaySettings[]
  payrollRecords    PayrollRecord[]
  payrollAuditLogs  PayrollAuditLog[]
  systemConfigs     SystemConfig[]
  notifications     Notification[]
  documents         EmployeeDocument[]
  documentTypes     DocumentType[]
  subscription      OrgSubscription?

  @@map("organizations")
}

// ============================================================
// USER — Platform-level identity
// Never deleted. Can always log in.
// Org-specific data lives on OrgMembership.
// ============================================================
model User {
  id         String  @id @default(uuid())
  email      String  @unique
  password   String
  firstName  String
  lastName   String
  phone      String?
  dateOfBirth DateTime? @db.Date
  platformId String? @unique

  // Role on User is only meaningful for SUPER_ADMIN.
  // For all other users, the effective role comes from OrgMembership.
  // Defaults to EMPLOYEE for non-super-admin users.
  role       Role    @default(EMPLOYEE)

  // Platform-level active flag.
  // If false, user cannot log in at all (banned/suspended from platform).
  // This is separate from OrgMembership.isActive (org-level).
  isActive   Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Platform-level soft delete (rarely used)

  // Platform-level relations (not org-scoped)
  sessions            UserSession[]
  passwordResetTokens PasswordResetToken[]
  memberships         OrgMembership[]

  // Leave approver relation stays on User (approvedBy is userId)
  approvedLeaves Leave[] @relation("ApprovedLeaves")

  @@map("users")
}

// ============================================================
// ORG MEMBERSHIP — Links a User to an Organization
// Holds all org-specific data: role, employeeId, shift, PIN, etc.
// One membership per user per org. Reactivated on rejoin.
// ============================================================
model OrgMembership {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Org-scoped role (EMPLOYEE, ORG_ADMIN, ORG_ACCOUNTANT — never SUPER_ADMIN)
  role Role @default(EMPLOYEE)

  // Org-scoped employee identity
  employeeId        String?
  attendancePinHash String?
  panNumber         String?

  // Individual shift override (null = follow org default)
  shiftStartTime String? // HH:mm format, e.g. "14:00"
  shiftEndTime   String? // HH:mm format, e.g. "18:00"

  // Membership lifecycle
  isActive Boolean   @default(true) // false = departed from org
  joinedAt DateTime  @default(now())
  leftAt   DateTime? // When the employee left the org (null = still active)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete timestamp for org-level removal

  // Org-scoped relations — all org data links here, not to User
  attendanceRecords AttendanceRecord[]
  paySettings       EmployeePaySettings?
  payrollRecords    PayrollRecord[]
  requestedLeaves   Leave[]              @relation("RequestedLeaves")
  createdQRCodes    QRCode[]             @relation("QRCodeCreator")
  notifications     Notification[]
  documents         EmployeeDocument[]

  // One membership per user per org (reactivate on rejoin, don't create duplicate)
  @@unique([userId, organizationId])
  // Employee ID unique within an org
  @@unique([organizationId, employeeId])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, role])
  @@map("org_memberships")
}

// ============================================================
// USER SESSION — JWT token tracking for secure logout
// Platform-level: tied to User, not membership
// ============================================================
model UserSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique // SHA-256 hash of the JWT
  isValid   Boolean  @default(true)
  expiresAt DateTime

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([userId, isValid])
  @@map("user_sessions")
}

// ============================================================
// QR CODE — Generated for attendance scanning
// Org-scoped: created by a membership
// ============================================================
model QRCode {
  id        String @id @default(uuid())
  token     String @unique
  signature String

  status    QRCodeStatus @default(ACTIVE)
  scanCount Int          @default(0)
  expiresAt DateTime?

  // Who created it (org-scoped — admin/accountant membership)
  createdByMembershipId String
  createdByMembership   OrgMembership @relation("QRCodeCreator", fields: [createdByMembershipId], references: [id])

  revokedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Multi-tenant (denormalized for fast queries)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  attendanceRecords AttendanceRecord[]

  @@index([organizationId])
  @@index([token])
  @@map("qr_codes")
}

// ============================================================
// ATTENDANCE RECORD — Clock-in / Clock-out tracking
// Org-scoped: tied to membership
// ============================================================
model AttendanceRecord {
  id           String        @id @default(uuid())
  membershipId String
  membership   OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Multi-tenant (denormalized — matches membership.organizationId)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  checkInTime    DateTime               @default(now())
  checkOutTime   DateTime?
  checkInMethod  CheckInMethod          @default(QR_SCAN)
  checkOutMethod CheckInMethod?

  duration Int? // Duration in minutes
  status   AttendanceRecordStatus @default(CHECKED_IN)

  // Which QR code was scanned (nullable for MANUAL entries)
  qrCodeId String?
  qrCode   QRCode? @relation(fields: [qrCodeId], references: [id])

  notes    String?
  isActive Boolean @default(true)

  // Manual correction tracking
  isManualEntry    Boolean   @default(false)
  modifiedBy       String?   // userId of admin who made the change
  modifiedAt       DateTime?
  modificationNote String?
  originalCheckIn  DateTime?
  originalCheckOut DateTime?

  // Nepali date fields (denormalized for fast queries/reports)
  bsYear  Int?
  bsMonth Int?
  bsDay   Int?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]

  @@index([membershipId])
  @@index([organizationId])
  @@index([checkInTime])
  @@index([membershipId, checkInTime])
  @@index([bsYear, bsMonth])
  @@index([organizationId, bsYear, bsMonth])
  @@index([membershipId, bsYear, bsMonth])
  @@map("attendance_records")
}

// ============================================================
// ATTENDANCE AUDIT LOG — Every scan attempt (success + failure)
// Plain strings, no FK — permanent audit trail
// ============================================================
model AttendanceAuditLog {
  id             String  @id @default(uuid())
  employeeId     String? // The employee ID entered (may not match a real user)
  userId         String? // Resolved user ID (null if employee not found)
  organizationId String?
  latitude       Float?   
  longitude      Float? 

  action    String // CLOCK_IN, CLOCK_OUT, FAILED
  method    String // QR_SCAN, MANUAL
  ipAddress String?
  userAgent String?

  success       Boolean
  failureReason String?

  qrToken String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
  @@index([ipAddress])
  @@map("attendance_audit_log")
}

// ============================================================
// EMPLOYEE PAY SETTINGS — Per-membership salary configuration
// Org-scoped: tied to membership
// ============================================================
model EmployeePaySettings {
  id           String        @id @default(uuid())
  membershipId String        @unique
  membership   OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Multi-tenant (denormalized)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  basicSalary         Decimal @db.Decimal(12, 2)
  dearnessAllowance   Decimal @default(0) @db.Decimal(12, 2)
  transportAllowance  Decimal @default(0) @db.Decimal(12, 2)
  medicalAllowance    Decimal @default(0) @db.Decimal(12, 2)
  otherAllowances     Decimal @default(0) @db.Decimal(12, 2)
  overtimeRatePerHour Decimal @default(0) @db.Decimal(10, 2)

  // SSF (Social Security Fund) — Nepal specific
  ssfEnabled      Boolean @default(true)
  employeeSsfRate Decimal @default(11) @db.Decimal(5, 2)
  employerSsfRate Decimal @default(20) @db.Decimal(5, 2)

  // PF (Provident Fund)
  pfEnabled      Boolean @default(false)
  employeePfRate Decimal @default(10) @db.Decimal(5, 2)
  employerPfRate Decimal @default(10) @db.Decimal(5, 2)

  // CIT (Citizen Investment Trust)
  citEnabled Boolean @default(false)
  citAmount  Decimal @default(0) @db.Decimal(12, 2)

  // Marital status — affects TDS first slab
  isMarried Boolean @default(false)

  // Advance/Loan deductions
  advanceDeduction Decimal @default(0) @db.Decimal(12, 2)

  // TDS (Tax Deducted at Source)
  tdsEnabled Boolean @default(true)

  // Bank details
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([membershipId])
  @@map("employee_pay_settings")
}

// ============================================================
// PAYROLL RECORD — Monthly payroll calculation results
// Org-scoped: tied to membership
// ============================================================
model PayrollRecord {
  id           String        @id @default(uuid())
  membershipId String
  membership   OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Multi-tenant (denormalized)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Period — both AD and BS
  year    Int // AD year
  month   Int // AD month
  bsYear  Int // BS year
  bsMonth Int // BS month

  // Attendance summary for this period
  workingDaysInMonth Int
  holidaysInMonth    Int     @default(0)
  daysPresent        Int
  daysAbsent         Int
  paidLeaveDays      Int     @default(0)
  unpaidLeaveDays    Int     @default(0)
  overtimeHours      Decimal @default(0) @db.Decimal(8, 2)

  // Earnings
  basicSalary        Decimal @db.Decimal(12, 2)
  dearnessAllowance  Decimal @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal @default(0) @db.Decimal(12, 2)
  medicalAllowance   Decimal @default(0) @db.Decimal(12, 2)
  otherAllowances    Decimal @default(0) @db.Decimal(12, 2)
  overtimePay        Decimal @default(0) @db.Decimal(12, 2)
  grossSalary        Decimal @db.Decimal(12, 2)

  // Deductions
  absenceDeduction Decimal @default(0) @db.Decimal(12, 2)
  employeeSsf      Decimal @default(0) @db.Decimal(12, 2)
  employerSsf      Decimal @default(0) @db.Decimal(12, 2)
  employeePf       Decimal @default(0) @db.Decimal(12, 2)
  employerPf       Decimal @default(0) @db.Decimal(12, 2)
  citDeduction     Decimal @default(0) @db.Decimal(12, 2)
  advanceDeduction Decimal @default(0) @db.Decimal(12, 2)
  dashainBonus     Decimal @default(0) @db.Decimal(12, 2)
  isMarried        Boolean @default(false)
  tds              Decimal @default(0) @db.Decimal(12, 2)
  otherDeductions  Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions  Decimal @default(0) @db.Decimal(12, 2)

  // Final
  netSalary Decimal @db.Decimal(12, 2)

  // Workflow
  status      PayrollStatus @default(DRAFT)
  processedAt DateTime?
  approvedAt  DateTime?
  paidAt      DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // One payroll record per membership per BS month
  @@unique([membershipId, bsYear, bsMonth])
  @@index([organizationId])
  @@index([bsYear, bsMonth])
  @@index([membershipId, bsYear, bsMonth])
  @@index([organizationId, bsYear, bsMonth])
  @@index([status])
  @@map("payroll_records")
}

// ============================================================
// HOLIDAY — Supports both national and org-specific holidays
// ============================================================
model Holiday {
  id String @id @default(uuid())

  // Multi-tenant — NULL = national holiday for all orgs
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name       String
  nameNepali String?

  // AD date
  date DateTime @db.Date

  // BS date (denormalized for fast lookup)
  bsYear  Int
  bsMonth Int
  bsDay   Int

  type        HolidayType @default(PUBLIC_HOLIDAY)
  isRecurring Boolean     @default(false)
  isActive    Boolean     @default(true)
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([bsYear, bsMonth, bsDay, organizationId])
  @@index([organizationId])
  @@index([date])
  @@index([bsYear, bsMonth])
  @@index([organizationId, bsYear])
  @@map("holidays")
}

// ============================================================
// LEAVE — Employee leave requests
// Org-scoped: requestor tied to membership, approver tied to User
// ============================================================
model Leave {
  id           String        @id @default(uuid())
  membershipId String
  membership   OrgMembership @relation("RequestedLeaves", fields: [membershipId], references: [id], onDelete: Cascade)

  // Multi-tenant (denormalized)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  // BS dates for the leave period
  bsStartYear  Int?
  bsStartMonth Int?
  bsStartDay   Int?
  bsEndYear    Int?
  bsEndMonth   Int?
  bsEndDay     Int?

  reason           String
  rejectionMessage String?
  type             LeaveType
  status           LeaveStatus @default(PENDING)

  // Approver stays as userId (not membershipId) — see design decisions
  approvedBy String?
  approver   User?     @relation("ApprovedLeaves", fields: [approvedBy], references: [id])
  approvedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([membershipId])
  @@index([organizationId])
  @@index([membershipId, status])
  @@index([organizationId, status])
  @@index([startDate, endDate])
  @@map("leaves")
}

// ============================================================
// SYSTEM CONFIG — Key-value settings per organization
// ============================================================
model SystemConfig {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  key         String
  value       String
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("system_configs")
}

// ============================================================
// NOTIFICATION
// Org-scoped: tied to membership (nullable for org-wide notifications)
// ============================================================
model Notification {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String

  // Nullable — org-wide notifications have no specific membership
  membershipId String?
  membership   OrgMembership? @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  attendanceId String?
  attendance   AttendanceRecord? @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId, isRead, createdAt])
  @@index([membershipId])
}

enum NotificationType {
  LATE_ARRIVAL
  EARLY_DEPARTURE
  LEAVE_REQUEST
  PAYROLL_APPROVED
  SYSTEM_ALERT
  ORG_STATUS_CHANGED
  PAYROLL_TOGGLED
  LEAVE_TOGGLED
  MASTER_HOLIDAYS_UPDATED
}

// ============================================================
// DOCUMENT TYPE — Org-admin defined categories
// ============================================================
model DocumentType {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  nameNp      String?
  description String?
  isRequired  Boolean @default(false)
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  documents EmployeeDocument[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("document_types")
}

// ============================================================
// EMPLOYEE DOCUMENT
// Org-scoped: tied to membership
// ============================================================
model EmployeeDocument {
  id             String        @id @default(uuid())
  membershipId   String
  membership     OrgMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentTypeId String
  documentType   DocumentType  @relation(fields: [documentTypeId], references: [id])

  fileName     String
  originalName String
  mimeType     String
  fileSize     Int
  description  String?

  // Plain string userId — who uploaded (audit trail, not org-scoped)
  uploadedBy String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([membershipId])
  @@index([organizationId])
  @@index([documentTypeId])
  @@map("employee_documents")
}

// ============================================================
// PRICING & SUBSCRIPTION (unchanged — no user/membership dependency)
// ============================================================

enum TierName {
  STARTER
  OPERATIONS
}

enum SubscriptionStatus {
  TRIALING
  GRACE_PERIOD
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

model PricingPlan {
  id          String   @id @default(uuid())
  tier        TierName @unique

  displayName String
  description String?

  pricePerEmployee      Decimal @default(0) @db.Decimal(10, 2)
  defaultSetupFee       Decimal? @db.Decimal(10, 2)
  currency              String  @default("NPR")

  maxEmployees          Int?

  trialDaysMonthly      Int @default(30)
  annualDiscountPercent Int @default(0)
  gracePeriodDays       Int @default(7)

  featureLeave            Boolean @default(false)
  featureManualCorrection Boolean @default(false)
  featureFullPayroll      Boolean @default(false)
  featurePayrollWorkflow  Boolean @default(false)
  featureReports          Boolean @default(false)
  featureNotifications    Boolean @default(false)
  featureOnboarding       Boolean @default(false)
  featureAuditLog         Boolean @default(false)
  auditLogRetentionDays   Int?

  featureFileDownload           Boolean @default(false)
  featureDownloadReports        Boolean @default(false)
  featureDownloadPayslips       Boolean @default(false)
  featureDownloadAuditLog       Boolean @default(false)
  featureDownloadLeaveRecords   Boolean @default(false)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions OrgSubscription[]
  featureTotp   Boolean @default(false)

  @@map("pricing_plans")
}

model SubscriptionAdminNote {
  id             String          @id @default(uuid())
  subscriptionId String
  subscription   OrgSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  note      String
  createdBy String
  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@map("subscription_admin_notes")
}

model OrgSubscription {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  planId String
  plan   PricingPlan @relation(fields: [planId], references: [id])

  status       SubscriptionStatus @default(TRIALING)
  billingCycle BillingCycle       @default(MONTHLY)

  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  isTrialUsed    Boolean @default(false)

  trialReminderSentAt       DateTime?
  trialFinalReminderAt      DateTime?
  billingReminderSentAt     DateTime?
  conversionNudgeSentAt     DateTime?
  graceEndsAt               DateTime?
  gracePeriodReminderSentAt DateTime?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextBillingDate    DateTime?
  cancelledAt        DateTime?
  suspendedAt        DateTime?

  currentEmployeeCount Int @default(0)

  customPricePerEmployee Decimal?  @db.Decimal(10, 2)
  customPriceExpiresAt   DateTime?
  customMaxEmployees     Int?

  overrideFeatureLeave                Boolean?
  overrideFeatureManualCorrection     Boolean?
  overrideFeatureFullPayroll          Boolean?
  overrideFeaturePayrollWorkflow      Boolean?
  overrideFeatureReports              Boolean?
  overrideFeatureNotifications        Boolean?
  overrideFeatureOnboarding           Boolean?
  overrideFeatureAuditLog             Boolean?
  overrideFeatureFileDownload         Boolean?
  overrideFeatureDownloadReports      Boolean?
  overrideFeatureDownloadPayslips     Boolean?
  overrideFeatureDownloadAuditLog     Boolean?
  overrideFeatureDownloadLeaveRecords Boolean?
  isPriceLockedForever Boolean @default(false)

  setupFeePaid       Boolean   @default(false)
  setupFeeAmount     Decimal?  @db.Decimal(10, 2)
  setupFeePaidAt     DateTime?
  setupFeeWaived     Boolean   @default(false)
  setupFeeWaivedBy   String?
  setupFeeWaivedNote String?

  parentSubscriptionId String?
  parentSubscription   OrgSubscription?  @relation("BranchSubscriptions", fields: [parentSubscriptionId], references: [id])
  branches             OrgSubscription[] @relation("BranchSubscriptions")

  assignedBy String?
  assignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billingHistory SubscriptionBillingLog[]
  adminNotes     SubscriptionAdminNote[]

  @@index([organizationId])
  @@index([status])
  @@index([planId])
  @@index([trialEndsAt])
  @@index([nextBillingDate])
  @@map("org_subscriptions")
}

model SubscriptionBillingLog {
  id             String          @id @default(uuid())
  subscriptionId String
  subscription   OrgSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  organizationId String
  performedBy    String?

  event      String
  fromPlan   String?
  toPlan     String?
  fromStatus String?
  toStatus   String?
  amount     Decimal? @db.Decimal(10, 2)
  employeeCount Int?
  note       String?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("subscription_billing_log")
}

model PlatformConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  valueType   String   @default("number")
  label       String
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("platform_config")
}

// ============================================================
// PASSWORD RESET TOKEN — Platform-level, tied to User
// ============================================================
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String?   @unique
  tokenHash String?   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ============================================================
// PAYROLL AUDIT LOG — Plain string references, no FK
// Permanent audit trail — survives membership deactivation
// ============================================================
model PayrollAuditLog {
  id                 String   @id @default(uuid())
  organizationId     String
  payrollRecordId    String?
  employeeUserId     String?  // Plain userId for auditability
  action             String
  fromStatus         String?
  toStatus           String?
  triggeredBy        String   // Plain userId of admin who triggered
  reason             String?
  attendanceRecordId String?
  bsYear             Int?
  bsMonth            Int?
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([payrollRecordId])
  @@index([employeeUserId])
  @@map("payroll_audit_logs")
}
