'use client';

import { useState, useEffect } from 'react';
import { useRouter } from 'next/navigation';
import { useAuth } from '@/contexts/auth-context';
import { api } from '@/lib/api';

interface User {
  id: string;
  email: string;
  firstName: string;
  lastName: string;
  employeeId: string;
  role: string;
  status: string;
}

interface QRCode {
  id: string;
  token: string;
  scanCount: number;
  createdAt: string;
}

interface AttendanceRecord {
  id: string;
  checkInTime: string;
  checkOutTime: string | null;
  duration: number | null;
  status: string;
  user: {
    firstName: string;
    lastName: string;
    employeeId: string;
  };
}

interface DailyReport {
  date: string;
  summary: {
    totalEmployees: number;
    totalPresent: number;
    totalAbsent: number;
    currentlyClockedIn: number;
    completedShifts: number;
    totalHoursWorked: number;
    avgHoursWorked: number;
    attendanceRate: number;
  };
  present: Array<{
    employee: { firstName: string; lastName: string; employeeId: string };
    checkInTime: string;
    checkOutTime: string | null;
    duration: number | null;
    status: string;
  }>;
  absent: Array<{ firstName: string; lastName: string; employeeId: string }>;
}

interface WeeklyReport {
  weekStart: string;
  weekEnd: string;
  summary: {
    totalEmployees: number;
    employeesWithAttendance: number;
    totalHoursWorked: number;
    avgHoursPerEmployee: number;
    avgDaysPerEmployee: number;
  };
  dailyBreakdown: Array<{
    date: string;
    dayName: string;
    presentCount: number;
    absentCount: number;
    totalHours: number;
  }>;
  employeeStats: Array<{
    employee: { firstName: string; lastName: string; employeeId: string };
    daysPresent: number;
    totalShifts: number;
    totalHours: number;
    avgHoursPerDay: number;
  }>;
}

export default function AdminDashboard() {
  const { user, isLoading, logout } = useAuth();
  const router = useRouter();
  const [users, setUsers] = useState<User[]>([]);
  const [qrCode, setQrCode] = useState<QRCode | null>(null);
  const [scanUrl, setScanUrl] = useState<string>('');
  const [qrImage, setQrImage] = useState<string>('');
  const [attendance, setAttendance] = useState<AttendanceRecord[]>([]);
  const [dailyReport, setDailyReport] = useState<DailyReport | null>(null);
  const [weeklyReport, setWeeklyReport] = useState<WeeklyReport | null>(null);
  const [reportDate, setReportDate] = useState(new Date().toISOString().split('T')[0]);
  const [weekStartDate, setWeekStartDate] = useState(() => {
    const d = new Date();
    const day = d.getDay();
    const diff = d.getDate() - day + (day === 0 ? -6 : 1);
    d.setDate(diff);
    return d.toISOString().split('T')[0];
  });
  const [activeTab, setActiveTab] = useState<'staff' | 'qr' | 'attendance' | 'daily' | 'weekly'>('staff');
  const [error, setError] = useState('');
  const [generating, setGenerating] = useState(false);

  useEffect(() => {
    if (!isLoading && (!user || user.role !== 'ADMIN')) {
      router.push('/login');
    }
  }, [user, isLoading, router]);

  useEffect(() => {
    if (user?.role === 'ADMIN') {
      loadData();
    }
  }, [user]);

  useEffect(() => {
    if (user?.role === 'ADMIN' && activeTab === 'daily') {
      loadDailyReport();
    }
  }, [user, activeTab, reportDate]);

  useEffect(() => {
    if (user?.role === 'ADMIN' && activeTab === 'weekly') {
      loadWeeklyReport();
    }
  }, [user, activeTab, weekStartDate]);

  const loadData = async () => {
    const [usersRes, qrRes, attendanceRes] = await Promise.all([
      api.get('/api/users'),
      api.get('/api/qr/active'),
      api.get('/api/attendance'),
    ]);

    if (usersRes.data) setUsers((usersRes.data as { users: User[] }).users);
    if (qrRes.data) {
      const data = qrRes.data as { qrCode: QRCode; scanUrl: string; qrImage: string };
      setQrCode(data.qrCode);
      setScanUrl(data.scanUrl);
      setQrImage(data.qrImage);
    }
    if (attendanceRes.data) setAttendance((attendanceRes.data as { records: AttendanceRecord[] }).records);
  };

  const loadDailyReport = async () => {
    const res = await api.get(`/api/reports/daily?date=${reportDate}`);
    if (res.data) setDailyReport(res.data as DailyReport);
  };

  const loadWeeklyReport = async () => {
    const res = await api.get(`/api/reports/weekly?startDate=${weekStartDate}`);
    if (res.data) setWeeklyReport(res.data as WeeklyReport);
  };

  const generateQR = async () => {
    setError('');
    setGenerating(true);
    const res = await api.post('/api/qr/generate');
    setGenerating(false);
    
    if (res.error) {
      setError(res.error.message);
    } else {
      const data = res.data as { qrCode: QRCode; scanUrl: string; qrImage: string };
      setQrCode(data.qrCode);
      setScanUrl(data.scanUrl);
      setQrImage(data.qrImage);
    }
  };

  const printQR = () => {
    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(`
        <html>
          <head><title>Attendance QR Code</title>
            <style>
              body { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; font-family: system-ui, sans-serif; margin: 0; }
              h1 { margin-bottom: 20px; } img { max-width: 400px; } p { color: #666; margin-top: 20px; }
            </style>
          </head>
          <body><h1>Scan to Clock In/Out</h1><img src="${qrImage}" alt="QR Code" /><p>Smart Attendance System</p></body>
        </html>
      `);
      printWindow.document.close();
      printWindow.print();
    }
  };

  const printDailyReport = () => {
    if (!dailyReport) return;
    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(`
        <html>
          <head><title>Daily Report - ${dailyReport.date}</title>
            <style>
              body { font-family: system-ui, sans-serif; padding: 20px; }
              h1 { text-align: center; }
              .summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin: 20px 0; }
              .stat { background: #f3f4f6; padding: 15px; border-radius: 8px; text-align: center; }
              .stat-value { font-size: 24px; font-weight: bold; }
              .stat-label { font-size: 12px; color: #666; }
              table { width: 100%; border-collapse: collapse; margin-top: 20px; }
              th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
              th { background: #f3f4f6; }
              .section-title { margin-top: 30px; font-size: 18px; font-weight: bold; }
            </style>
          </head>
          <body>
            <h1>Daily Attendance Report</h1>
            <p style="text-align: center; color: #666;">${dailyReport.date}</p>
            <div class="summary">
              <div class="stat"><div class="stat-value">${dailyReport.summary.totalPresent}</div><div class="stat-label">Present</div></div>
              <div class="stat"><div class="stat-value">${dailyReport.summary.totalAbsent}</div><div class="stat-label">Absent</div></div>
              <div class="stat"><div class="stat-value">${dailyReport.summary.attendanceRate}%</div><div class="stat-label">Attendance Rate</div></div>
              <div class="stat"><div class="stat-value">${dailyReport.summary.totalHoursWorked}h</div><div class="stat-label">Total Hours</div></div>
            </div>
            <div class="section-title">Present (${dailyReport.present.length})</div>
            <table>
              <tr><th>Employee</th><th>Check In</th><th>Check Out</th><th>Duration</th><th>Status</th></tr>
              ${dailyReport.present.map(p => `<tr><td>${p.employee.firstName} ${p.employee.lastName} (${p.employee.employeeId})</td><td>${new Date(p.checkInTime).toLocaleTimeString()}</td><td>${p.checkOutTime ? new Date(p.checkOutTime).toLocaleTimeString() : '-'}</td><td>${p.duration ? Math.floor(p.duration / 60) + 'h ' + (p.duration % 60) + 'm' : '-'}</td><td>${p.status}</td></tr>`).join('')}
            </table>
            ${dailyReport.absent.length > 0 ? `<div class="section-title">Absent (${dailyReport.absent.length})</div><table><tr><th>Employee ID</th><th>Name</th></tr>${dailyReport.absent.map(a => `<tr><td>${a.employeeId}</td><td>${a.firstName} ${a.lastName}</td></tr>`).join('')}</table>` : ''}
          </body>
        </html>
      `);
      printWindow.document.close();
      printWindow.print();
    }
  };

  const printWeeklyReport = () => {
    if (!weeklyReport) return;
    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(`
        <html>
          <head><title>Weekly Report - ${weeklyReport.weekStart} to ${weeklyReport.weekEnd}</title>
            <style>
              body { font-family: system-ui, sans-serif; padding: 20px; }
              h1 { text-align: center; }
              .summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin: 20px 0; }
              .stat { background: #f3f4f6; padding: 15px; border-radius: 8px; text-align: center; }
              .stat-value { font-size: 24px; font-weight: bold; }
              .stat-label { font-size: 12px; color: #666; }
              table { width: 100%; border-collapse: collapse; margin-top: 20px; }
              th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
              th { background: #f3f4f6; }
              .section-title { margin-top: 30px; font-size: 18px; font-weight: bold; }
            </style>
          </head>
          <body>
            <h1>Weekly Attendance Report</h1>
            <p style="text-align: center; color: #666;">${weeklyReport.weekStart} to ${weeklyReport.weekEnd}</p>
            <div class="summary">
              <div class="stat"><div class="stat-value">${weeklyReport.summary.totalEmployees}</div><div class="stat-label">Total Employees</div></div>
              <div class="stat"><div class="stat-value">${weeklyReport.summary.totalHoursWorked}h</div><div class="stat-label">Total Hours</div></div>
              <div class="stat"><div class="stat-value">${weeklyReport.summary.avgHoursPerEmployee}h</div><div class="stat-label">Avg Hours/Employee</div></div>
              <div class="stat"><div class="stat-value">${weeklyReport.summary.avgDaysPerEmployee}</div><div class="stat-label">Avg Days/Employee</div></div>
            </div>
            <div class="section-title">Daily Breakdown</div>
            <table>
              <tr><th>Day</th><th>Date</th><th>Present</th><th>Absent</th><th>Total Hours</th></tr>
              ${weeklyReport.dailyBreakdown.map(d => `<tr><td>${d.dayName}</td><td>${d.date}</td><td>${d.presentCount}</td><td>${d.absentCount}</td><td>${d.totalHours}h</td></tr>`).join('')}
            </table>
            <div class="section-title">Employee Summary</div>
            <table>
              <tr><th>Employee</th><th>Days Present</th><th>Total Hours</th><th>Avg Hours/Day</th></tr>
              ${weeklyReport.employeeStats.map(e => `<tr><td>${e.employee.firstName} ${e.employee.lastName} (${e.employee.employeeId})</td><td>${e.daysPresent}</td><td>${e.totalHours}h</td><td>${e.avgHoursPerDay}h</td></tr>`).join('')}
            </table>
          </body>
        </html>
      `);
      printWindow.document.close();
      printWindow.print();
    }
  };

  const changeWeek = (direction: number) => {
    const d = new Date(weekStartDate);
    d.setDate(d.getDate() + (direction * 7));
    setWeekStartDate(d.toISOString().split('T')[0]);
  };

  if (isLoading) return <div className="min-h-screen flex items-center justify-center">Loading...</div>;
  if (!user || user.role !== 'ADMIN') return null;

  return (
    <div className="min-h-screen bg-gray-100">
      <nav className="bg-white shadow">
        <div className="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
          <h1 className="text-xl font-bold">Admin Dashboard</h1>
          <div className="flex items-center gap-4">
            <span className="text-gray-600">{user.firstName} {user.lastName}</span>
            <button onClick={logout} className="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">Logout</button>
          </div>
        </div>
      </nav>

      <div className="max-w-7xl mx-auto px-4 py-6">
        {error && <div className="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{error}</div>}

        <div className="flex gap-2 mb-6 flex-wrap">
          {['staff', 'qr', 'attendance', 'daily', 'weekly'].map((tab) => (
            <button
              key={tab}
              onClick={() => setActiveTab(tab as typeof activeTab)}
              className={`px-4 py-2 rounded ${activeTab === tab ? 'bg-blue-500 text-white' : 'bg-white'}`}
            >
              {tab === 'daily' ? 'Daily Report' : tab === 'weekly' ? 'Weekly Report' : tab.charAt(0).toUpperCase() + tab.slice(1)}
            </button>
          ))}
        </div>

        {activeTab === 'staff' && (
          <div className="bg-white rounded-lg shadow p-6">
            <h2 className="text-lg font-semibold mb-4">Staff List</h2>
            <table className="w-full">
              <thead><tr className="border-b"><th className="text-left py-2">Employee ID</th><th className="text-left py-2">Name</th><th className="text-left py-2">Email</th><th className="text-left py-2">Role</th><th className="text-left py-2">Status</th></tr></thead>
              <tbody>
                {users.map((u) => (
                  <tr key={u.id} className="border-b">
                    <td className="py-2">{u.employeeId}</td>
                    <td className="py-2">{u.firstName} {u.lastName}</td>
                    <td className="py-2">{u.email}</td>
                    <td className="py-2">{u.role}</td>
                    <td className="py-2"><span className={`px-2 py-1 rounded text-sm ${u.status === 'ACTIVE' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>{u.status}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {activeTab === 'qr' && (
          <div className="bg-white rounded-lg shadow p-6">
            <h2 className="text-lg font-semibold mb-4">Static QR Code</h2>
            <div className="flex gap-4 mb-6">
              <button onClick={generateQR} disabled={generating} className="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 disabled:bg-blue-300">{generating ? 'Generating...' : 'Generate New QR Code'}</button>
              {qrImage && <button onClick={printQR} className="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600">Print QR Code</button>}
            </div>
            {qrCode && qrImage && (
              <div className="flex flex-col items-center">
                <div className="bg-white p-4 border-2 border-gray-200 rounded-lg mb-4"><img src={qrImage} alt="QR Code" className="w-64 h-64" /></div>
                <p className="text-sm text-gray-600 mb-2">Created: {new Date(qrCode.createdAt).toLocaleString()}</p>
                <p className="text-sm text-gray-600 mb-4">Scan count: {qrCode.scanCount}</p>
                <p className="text-sm text-green-600 mb-2">✓ Employees can scan this with their phone camera</p>
                <details className="w-full max-w-md"><summary className="cursor-pointer text-sm text-gray-500 hover:text-gray-700">Show scan URL</summary><div className="mt-2 bg-gray-100 p-3 rounded"><p className="text-xs font-mono break-all">{scanUrl}</p></div></details>
              </div>
            )}
            {!qrCode && <p className="text-gray-500 text-center py-8">No active QR code. Click &quot;Generate New QR Code&quot; to create one.</p>}
          </div>
        )}

        {activeTab === 'attendance' && (
          <div className="bg-white rounded-lg shadow p-6">
            <h2 className="text-lg font-semibold mb-4">Attendance Records</h2>
            <table className="w-full">
              <thead><tr className="border-b"><th className="text-left py-2">Employee</th><th className="text-left py-2">Check In</th><th className="text-left py-2">Check Out</th><th className="text-left py-2">Duration</th><th className="text-left py-2">Status</th></tr></thead>
              <tbody>
                {attendance.map((record) => (
                  <tr key={record.id} className="border-b">
                    <td className="py-2">{record.user.firstName} {record.user.lastName}<span className="text-gray-500 text-sm ml-2">({record.user.employeeId})</span></td>
                    <td className="py-2">{new Date(record.checkInTime).toLocaleTimeString()}</td>
                    <td className="py-2">{record.checkOutTime ? new Date(record.checkOutTime).toLocaleTimeString() : '-'}</td>
                    <td className="py-2">{record.duration ? `${Math.floor(record.duration / 60)}h ${record.duration % 60}m` : '-'}</td>
                    <td className="py-2"><span className={`px-2 py-1 rounded text-sm ${record.status === 'CHECKED_IN' ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800'}`}>{record.status}</span></td>
                  </tr>
                ))}
                {attendance.length === 0 && <tr><td colSpan={5} className="py-4 text-center text-gray-500">No attendance records yet</td></tr>}
              </tbody>
            </table>
          </div>
        )}

        {activeTab === 'daily' && (
          <div className="space-y-6">
            <div className="bg-white rounded-lg shadow p-6">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-4">
                  <h2 className="text-lg font-semibold">Daily Report</h2>
                  <input type="date" value={reportDate} onChange={(e) => setReportDate(e.target.value)} className="px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-blue-500" />
                </div>
                <button onClick={printDailyReport} className="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600">Print Report</button>
              </div>
            </div>
            {dailyReport && (
              <>
                <div className="grid grid-cols-4 gap-4">
                  <div className="bg-white rounded-lg shadow p-6 text-center"><div className="text-3xl font-bold text-green-600">{dailyReport.summary.totalPresent}</div><div className="text-gray-600 text-sm">Present</div></div>
                  <div className="bg-white rounded-lg shadow p-6 text-center"><div className="text-3xl font-bold text-red-600">{dailyReport.summary.totalAbsent}</div><div className="text-gray-600 text-sm">Absent</div></div>
                  <div className="bg-white rounded-lg shadow p-6 text-center"><div className="text-3xl font-bold text-blue-600">{dailyReport.summary.attendanceRate}%</div><div className="text-gray-600 text-sm">Attendance Rate</div></div>
                  <div className="bg-white rounded-lg shadow p-6 text-center"><div className="text-3xl font-bold text-purple-600">{dailyReport.summary.totalHoursWorked}h</div><div className="text-gray-600 text-sm">Total Hours</div></div>
                </div>
                <div className="bg-white rounded-lg shadow p-6">
                  <h3 className="text-lg font-semibold mb-4 text-green-600">Present ({dailyReport.present.length})</h3>
                  <table className="w-full">
                    <thead><tr className="border-b"><th className="text-left py-2">Employee</th><th className="text-left py-2">Check In</th><th className="text-left py-2">Check Out</th><th className="text-left py-2">Duration</th><th className="text-left py-2">Status</th></tr></thead>
                    <tbody>
                      {dailyReport.present.map((record, idx) => (
                        <tr key={idx} className="border-b">
                          <td className="py-2">{record.employee.firstName} {record.employee.lastName}<span className="text-gray-500 text-sm ml-2">({record.employee.employeeId})</span></td>
                          <td className="py-2">{new Date(record.checkInTime).toLocaleTimeString()}</td>
                          <td className="py-2">{record.checkOutTime ? new Date(record.checkOutTime).toLocaleTimeString() : '-'}</td>
                          <td className="py-2">{record.duration ? `${Math.floor(record.duration / 60)}h ${record.duration % 60}m` : '-'}</td>
                          <td className="py-2"><span className={`px-2 py-1 rounded text-sm ${record.status === 'CHECKED_IN' ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800'}`}>{record.status}</span></td>
                        </tr>
                      ))}
                      {dailyReport.present.length === 0 && <tr><td colSpan={5} className="py-4 text-center text-gray-500">No one clocked in yet</td></tr>}
                    </tbody>
                  </table>
                </div>
                {dailyReport.absent.length > 0 && (
                  <div className="bg-white rounded-lg shadow p-6">
                    <h3 className="text-lg font-semibold mb-4 text-red-600">Absent ({dailyReport.absent.length})</h3>
                    <div className="grid grid-cols-3 gap-4">
                      {dailyReport.absent.map((emp, idx) => (<div key={idx} className="border rounded p-3"><div className="font-medium">{emp.firstName} {emp.lastName}</div><div className="text-sm text-gray-500">{emp.employeeId}</div></div>))}
                    </div>
                  </div>
                )}
              </>
            )}
          </div>
        )}

        {activeTab === 'weekly' && (
          <div className="space-y-6">
            <div className="bg-white rounded-lg shadow p-6">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-4">
                  <h2 className="text-lg font-semibold">Weekly Report</h2>
                  <button onClick={() => changeWeek(-1)} className="px-3 py-1 bg-gray-200 rounded hover:bg-gray-300">← Prev</button>
                  <span className="text-gray-600">{weekStartDate} to {new Date(new Date(weekStartDate).getTime() + 6 * 24 * 60 * 60 * 1000).toISOString().split('T')[0]}</span>
                  <button onClick={() => changeWeek(1)} className="px-3 py-1 bg-gray-200 rounded hover:bg-gray-300">Next →</button>
                </div>
                <button onClick={printWeeklyReport} className="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600">Print Report</button>
              </div>
            </div>
            {weeklyReport && (
              <>
                <div className="grid grid-cols-4 gap-4">
                  <div className="bg-white rounded-lg shadow p-6 text-center"><div className="text-3xl font-bold text-blue-600">{weeklyReport.summary.totalEmployees}</div><div className="text-gray-600 text-sm">Total Employees</div></div>
                  <div className="bg-white rounded-lg shadow p-6 text-center"><div className="text-3xl font-bold text-green-600">{weeklyReport.summary.totalHoursWorked}h</div><div className="text-gray-600 text-sm">Total Hours</div></div>
                  <div className="bg-white rounded-lg shadow p-6 text-center"><div className="text-3xl font-bold text-purple-600">{weeklyReport.summary.avgHoursPerEmployee}h</div><div className="text-gray-600 text-sm">Avg Hours/Employee</div></div>
                  <div className="bg-white rounded-lg shadow p-6 text-center"><div className="text-3xl font-bold text-orange-600">{weeklyReport.summary.avgDaysPerEmployee}</div><div className="text-gray-600 text-sm">Avg Days/Employee</div></div>
                </div>
                <div className="bg-white rounded-lg shadow p-6">
                  <h3 className="text-lg font-semibold mb-4">Daily Breakdown</h3>
                  <table className="w-full">
                    <thead><tr className="border-b"><th className="text-left py-2">Day</th><th className="text-left py-2">Date</th><th className="text-left py-2">Present</th><th className="text-left py-2">Absent</th><th className="text-left py-2">Total Hours</th></tr></thead>
                    <tbody>
                      {weeklyReport.dailyBreakdown.map((day, idx) => (
                        <tr key={idx} className="border-b">
                          <td className="py-2 font-medium">{day.dayName}</td>
                          <td className="py-2">{day.date}</td>
                          <td className="py-2"><span className="text-green-600">{day.presentCount}</span></td>
                          <td className="py-2"><span className="text-red-600">{day.absentCount}</span></td>
                          <td className="py-2">{day.totalHours}h</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
                <div className="bg-white rounded-lg shadow p-6">
                  <h3 className="text-lg font-semibold mb-4">Employee Summary</h3>
                  <table className="w-full">
                    <thead><tr className="border-b"><th className="text-left py-2">Employee</th><th className="text-left py-2">Days Present</th><th className="text-left py-2">Total Hours</th><th className="text-left py-2">Avg Hours/Day</th></tr></thead>
                    <tbody>
                      {weeklyReport.employeeStats.map((emp, idx) => (
                        <tr key={idx} className="border-b">
                          <td className="py-2">{emp.employee.firstName} {emp.employee.lastName}<span className="text-gray-500 text-sm ml-2">({emp.employee.employeeId})</span></td>
                          <td className="py-2">{emp.daysPresent} / 7</td>
                          <td className="py-2">{emp.totalHours}h</td>
                          <td className="py-2">{emp.avgHoursPerDay}h</td>
                        </tr>
                      ))}
                      {weeklyReport.employeeStats.length === 0 && <tr><td colSpan={4} className="py-4 text-center text-gray-500">No data for this week</td></tr>}
                    </tbody>
                  </table>
                </div>
              </>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
