{
  "expo": {
    "name": "Attend Xpress Admin",
    "slug": "attendxpress-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "bundleIdentifier": "com.yourcompany.attendxpress.admin",
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9FAFB"
      },
      "package": "com.yourcompany.attendxpress.admin",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "attendxpress-admin",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eaec5037-7f5c-42f2-ab93-eb1603e2fe1e"
      }
    }
  }
}
