{
  "expo": {
    "name": "Attend Xpress Admin",
    "slug": "attendxpress-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "bundleIdentifier": "com.zentaralabs.attendxpress.admin",
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9FAFB"
      },
      "package": "com.zentaralabs.attendxpress.admin",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Attend Xpress Admin needs camera access to scan QR codes."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Attend Xpress Admin needs your location to verify attendance."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "attendxpress-admin",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3b9521d0-76fa-4eff-b0f9-08ab24873ccf"
      }
    },
    "owner": "romanlama"
  }
}
